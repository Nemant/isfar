---
/* Shared shell for the zero-island static pages (route pages, hubs, /ar/
   landing, 404). Same head/theme/chrome pattern as the far-north guide:
   pre-paint theme script, no <meta theme-color> (iOS translucent bars),
   vanilla theme toggle, SW registration. Content goes in the default slot,
   inside .post-col. */
import '../styles/styles.css';
import '../styles/blog.css';

const {
  title, desc, url,
  lang = 'en', dir = 'ltr',
  ogType = 'website',
  jsonld = [],          // array of JSON-LD objects, one <script> each
  alternates = [],      // [{ lang: 'en'|'ar'|'x-default', href }]
  noindex = false,      // 404 page
} = Astro.props;
---
<!DOCTYPE html>
<html lang={lang} dir={dir}>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<!-- No <meta theme-color> — same iOS translucent-bars reasoning as index.astro. -->

<script is:inline>
  (function () {
    try {
      var saved = localStorage.getItem("isfar.theme");
      var pref = (saved === "light" || saved === "dark") ? saved
        : (window.matchMedia && matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
      document.documentElement.setAttribute("data-theme", pref);
    } catch (e) {}
  })();
</script>

<title>{title}</title>
<meta name="description" content={desc} />
{noindex ? <meta name="robots" content="noindex" /> : <link rel="canonical" href={url} />}
{alternates.map((a) => <link rel="alternate" hreflang={a.lang} href={a.href} />)}

<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="Isfar" />
<meta property="og:title" content={title} />
<meta property="og:description" content={desc} />
<meta property="og:url" content={url} />
<meta property="og:image" content="https://isfar.app/og-cover.png?v=2" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={desc} />
<meta name="twitter:image" content="https://isfar.app/og-cover.png?v=2" />

{jsonld.map((obj) => <script type="application/ld+json" set:html={JSON.stringify(obj)} />)}

<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
<link rel="manifest" href="/manifest.webmanifest" />
<link rel="apple-touch-icon" href="/icon-192.png" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="Isfar" />
<meta name="mobile-web-app-capable" content="yes" />

<link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/newsreader-latin-400.woff2" />
<link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/hanken-grotesk-latin-400.woff2" />
{lang === 'ar' && <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/noto-kufi-arabic-400.woff2" />}

<!-- Cloudflare Web Analytics (cookieless, no consent banner). Public site token. -->
<script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token":"5c747a2726d345e59c36739ba0d4fb15"}'></script>
</head>
<body>
<div class="isfar" id="page">
  <div class="sky" aria-hidden="true"></div>
  <script is:inline>
    document.getElementById("page").setAttribute(
      "data-theme", document.documentElement.getAttribute("data-theme") || "light");
  </script>

  <div class="post-col">
    <header class="hdr">
      <a class="brand" href={lang === 'ar' ? '/ar/' : '/'} aria-label="Isfar — prayer times across your flight" style="text-decoration:none;color:inherit">
        <span class="mark">Isfar</span>
        <span class="mark-ar ar" aria-hidden="true">إسفار</span>
      </a>
      <div class="hdr-actions">
        <button class="iconbtn" id="themebtn" aria-label="Switch theme">
          <svg class="tt-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
          <svg class="tt-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
        </button>
      </div>
    </header>

    <slot />
  </div>
</div>

<script is:inline>
  (function () {
    var btn = document.getElementById("themebtn");
    if (!btn) return;
    btn.addEventListener("click", function () {
      var html = document.documentElement;
      var next = html.getAttribute("data-theme") === "dark" ? "light" : "dark";
      html.setAttribute("data-theme", next);
      var page = document.getElementById("page");
      if (page) page.setAttribute("data-theme", next);
      try { localStorage.setItem("isfar.theme", next); } catch (e) {}
    });
  })();
  if ("serviceWorker" in navigator) {
    window.addEventListener("load", function () {
      navigator.serviceWorker.register("/sw.js").catch(function () {});
    });
  }
</script>
</body>
</html>
