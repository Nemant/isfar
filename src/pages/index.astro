</head>
<body>
<h1 class="sr-only">Isfar — prayer times across your flight, from Fajr to Isha</h1>
<div id="root"><Calculator client:only="react" /></div>

<!-- Calm footer below the client:only island. The homepage's crawlable signals
     are the <title>/<meta>/<h1 class="sr-only">/WebApplication JSON-LD plus the
     keyword-bearing nav links below — no visible body copy needed. The FAQ lives
     on its own /faq/ page with the FAQPage JSON-LD. -->
<section class="static-info" aria-label="About Isfar">
  <div class="horizon-rule" aria-hidden="true"></div>

  <nav class="static-links" aria-label="More from Isfar">
    <a href="/prayer-times/">Prayer times by route</a>
    <a href="/faq/">Prayer &amp; travel FAQ</a>
    <a href="/guide/far-north-prayer-times/">Guide: praying in the far north</a>
    <a href="/ar/" lang="ar" dir="rtl">إسفار بالعربية</a>
  </nav>
  <p class="static-foot">Free · installs as an app · no account · nothing here is a fiqh ruling — follow your own scholars.</p>
</section>

<script is:inline>
  if ("serviceWorker" in navigator) {
    window.addEventListener("load", function () {
      navigator.serviceWorker.register("/sw.js").catch(function () {});
    });
  }
</script>
</body>
</html>
