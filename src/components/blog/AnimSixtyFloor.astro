---
// "The 60° floor" — the round-down made visible on a quiet schematic map.
// The longitude axis is BROKEN (standard axis-break marks) so Anchorage sits
// beside the Nordic cluster instead of an ocean away; the cluster itself is
// spread wide (≈12 px/° lon) so the city labels stay large. 480-unit viewBox
// keeps all type legible at phone widths. Latitudes are true: y = f(lat).
const Y = (lat) => +(14 + (72 - lat) * 15).toFixed(1);
const X = (lon) => +(150 + (lon - 7) * 11.92).toFixed(1);   // right (Nordic) panel

const Y60 = Y(60);            // 194
const ARCTIC_Y = Y(66.56);    // 95.7
// parallel: west stub (Anchorage) ⫽ break ⫽ the Nordic span
const PAR_W = { x1: 10, x2: 104 };
const PAR_E = { x1: 136, x2: 462 };
const PAR_LEN = PAR_E.x2 - PAR_E.x1 + 4;

const LAT_LINES = [65, 70].map((l) => ({ y: Y(l) }));
const LON_LINES = [10, 15, 20, 25, 30].map((l) => X(l));

const CITIES = [
  { n: "Anchorage",     x: 58,       y: Y(61.2),  lx: 58,  ly: 196, anchor: "middle" },
  { n: "Oslo",          x: X(10.75), y: Y(59.91), lx: 195, ly: 222, anchor: "middle" },
  // Stockholm sits 14 px from the estimate ring (that proximity IS the story),
  // so its label drops to a second row on a short leader, clear of the knot
  { n: "Stockholm",     x: X(18.07), y: Y(59.33), lx: 282, ly: 242, anchor: "middle", leader: "M282 210 V231" },
  { n: "Helsinki",      x: X(24.94), y: Y(60.17), lx: 364, ly: 180, anchor: "middle" },
  { n: "St Petersburg", x: X(30.36), y: Y(59.93), lx: 466, ly: 222, anchor: "end" },
];

const TROMSO = { x: X(18.96), y: Y(69.65) };          // 292.6, 49.3
const DROP = `M${TROMSO.x} 56 V188.5`;                // dashed fall to the parallel
const DROP_REVEAL = `M${TROMSO.x} 54 V192`;           // mask path, length ≈ 138
---

<figure class="anim" data-anim="sixty-floor" style={`--par-len:${PAR_LEN}`}>
  <svg
    viewBox="0 0 480 300"
    role="img"
    aria-label="Schematic map of the far north with a broken longitude axis. The 60th parallel is highlighted, with Anchorage to the west and Oslo, Stockholm, Helsinki and St Petersburg clustered on or near it. Tromsø sits far above, beyond the Arctic Circle; a dashed line drops from Tromsø down its own longitude to a hollow estimate marker on the 60° line, where its prayer times are computed when its sky fails."
  >
    <defs>
      <!-- explicit user-space region: the masked drop is a perfectly vertical
           line whose bounding box has ZERO width, and a mask's default region
           is sized from that bbox — 120% of nothing hides the line entirely -->
      <mask id="sixty-floor-drop-m" maskUnits="userSpaceOnUse" x="284" y="44" width="18" height="156">
        <path class="drop-reveal" d={DROP_REVEAL} fill="none" stroke="#fff" stroke-width="5" />
      </mask>
    </defs>

    <!-- graticule (drawn in two panels either side of the axis break) -->
    <g class="grat">
      {LAT_LINES.map(({ y }) => <line x1="10" x2="104" y1={y} y2={y} class="lat" />)}
      {LAT_LINES.map(({ y }) => <line x1="136" x2="466" y1={y} y2={y} class="lat" />)}
      <line x1="58" x2="58" y1="18" y2="282" class="lon" />
      {LON_LINES.map((x) => <line x1={x} x2={x} y1="18" y2="282" class="lon" />)}
    </g>

    <!-- Arctic Circle -->
    <line class="arctic" x1="10" x2="104" y1={ARCTIC_Y} y2={ARCTIC_Y} />
    <line class="arctic" x1="136" x2="466" y1={ARCTIC_Y} y2={ARCTIC_Y} />
    <text class="axis arctic-lbl" x="10" y={ARCTIC_Y - 6}>Arctic Circle</text>

    <!-- THE line: the 60th parallel, broken between the continents -->
    <g class="par-west">
      <line class="parw" x1={PAR_W.x1} x2={PAR_W.x2} y1={Y60} y2={Y60} />
      <line class="brk" x1="114" y1={Y60 + 7} x2="123" y2={Y60 - 7} />
      <line class="brk" x1="121" y1={Y60 + 7} x2="130" y2={Y60 - 7} />
    </g>
    <line class="par" x1={PAR_E.x1} x2={PAR_E.x2} y1={Y60} y2={Y60} />
    <text class="par-lbl" x={PAR_E.x2} y={Y60 - 8} text-anchor="end">60°N</text>

    <!-- cities of the 60° cluster -->
    {CITIES.map((c, i) => (
      <g class={`city c${i}`}>
        {c.leader && <path class="leader" d={c.leader} />}
        <circle class="dot" cx={c.x} cy={c.y} r="3.5" />
        <text class="city-lbl" x={c.lx} y={c.ly} text-anchor={c.anchor}>{c.n}</text>
      </g>
    ))}

    <!-- Tromsø, beyond the circle -->
    <g class="tromso">
      <circle class="tromso-dot" cx={TROMSO.x} cy={TROMSO.y} r="4" />
      <text class="city-lbl tromso-lbl" x={TROMSO.x + 11} y={TROMSO.y + 4}>Tromsø</text>
    </g>

    <!-- the round-down: dashed fall to 60° -->
    <path class="drop" d={DROP} mask="url(#sixty-floor-drop-m)" />

    <!-- the estimate: hollow dashed ring on the parallel, explained by a quiet
         legend in the map's empty south-west (no leader crossing the cluster) -->
    <g class="est">
      <circle class="est-ring" cx={TROMSO.x} cy={Y60} r="4.5" />
      <circle class="est-ring" cx="26" cy="256" r="4.5" />
      <text class="est-lbl" x="38" y="251">when Tromsø’s sky fails,</text>
      <text class="est-lbl" x="38" y="268">its night’s times are computed here</text>
    </g>
  </svg>

  <figcaption>
    The 60th parallel is where the world’s big northern cities stop — Stockholm, Oslo,
    St&nbsp;Petersburg, Helsinki, and Anchorage just above (an ocean further west — note the
    break in the line). When a calculation has nowhere real to stand further north, Isfar
    computes it at 60° on your own longitude: a lived sky, not a mathematical sliver.
  </figcaption>
</figure>

<style>
  svg { width: 100%; height: auto; display: block; }
  svg text { font-size: 13px; }

  /* quiet bones */
  .lat { stroke: var(--text-mute); stroke-width: 1; opacity: 0.12; }
  .lon { stroke: var(--text-mute); stroke-width: 1; opacity: 0.07; }
  .axis {
    fill: var(--text-mute);
    opacity: 0.7;
    letter-spacing: 0.06em;
  }
  .arctic {
    stroke: oklch(from var(--text-mute) l c h / 0.4);
    stroke-width: 1;
    stroke-dasharray: 5 5;
  }
  .arctic-lbl { opacity: 0.6; font-size: 12px; }
  .leader { stroke: oklch(from var(--text-mute) l c h / 0.4); stroke-width: 0.75; fill: none; }

  /* THE line */
  .par {
    stroke: var(--accent);
    stroke-width: 2;
    stroke-linecap: round;
    filter: drop-shadow(0 0 calc(3px * var(--glow, 1)) oklch(from var(--accent) l c h / 0.5));
    stroke-dasharray: var(--par-len);
    stroke-dashoffset: var(--par-len);
    transition: stroke-dashoffset 2.5s ease-in-out;
  }
  .parw {
    stroke: var(--accent);
    stroke-width: 2;
    stroke-linecap: round;
    filter: drop-shadow(0 0 calc(3px * var(--glow, 1)) oklch(from var(--accent) l c h / 0.5));
  }
  .brk { stroke: var(--text-mute); stroke-width: 1.25; opacity: 0.6; }
  .par-west { opacity: 0; transition: opacity 0.6s ease-in-out 2.2s; }
  .par-lbl {
    fill: var(--accent);
    font-size: 13px;
    letter-spacing: 0.06em;
    opacity: 0;
    transition: opacity 0.6s ease-in-out 2.2s;
  }

  /* cities: staggered fade ~120ms apart after the parallel finishes */
  .city { opacity: 0; transition: opacity 0.55s ease-in-out; }
  .c0 { transition-delay: 2.6s; }
  .c1 { transition-delay: 2.72s; }
  .c2 { transition-delay: 2.84s; }
  .c3 { transition-delay: 2.96s; }
  .c4 { transition-delay: 3.08s; }
  .dot { fill: var(--text-soft); }
  .city-lbl { fill: var(--text-mute); }

  /* Tromsø */
  .tromso { opacity: 0; transition: opacity 0.55s ease-in-out 3.35s; }
  .tromso-dot {
    fill: var(--sky-maghrib);
    filter: drop-shadow(0 0 calc(3px * var(--glow, 1)) oklch(from var(--sky-maghrib) l c h / 0.55));
  }
  .tromso-lbl { fill: var(--text-soft); }

  /* the fall to 60°: dashed line revealed top-to-bottom via mask */
  .drop {
    stroke: oklch(from var(--sky-maghrib) l c h / 0.75);
    stroke-width: 1.6;
    stroke-dasharray: 3 4;
    fill: none;
  }
  .drop-reveal {
    stroke-dasharray: 140;
    stroke-dashoffset: 140;
    transition: stroke-dashoffset 1.6s ease-in-out 3.9s;
  }

  /* the estimate ring + serif moment */
  .est { opacity: 0; transition: opacity 0.8s ease-in-out 5.5s; }
  .est-ring {
    fill: none;
    stroke: oklch(from var(--sky-maghrib) l c h / 0.9);
    stroke-width: 1.3;
    stroke-dasharray: 2.2 2.6;
  }
  .est-lbl {
    fill: var(--text-soft);
    font-family: "Newsreader", serif;
    font-style: italic;
    font-size: 13.5px;
  }

  /* on scroll-in */
  figure.in .par, figure.in .drop-reveal { stroke-dashoffset: 0; }
  figure.in .par-lbl, figure.in .par-west, figure.in .city,
  figure.in .tromso, figure.in .est { opacity: 1; }

  @media (prefers-reduced-motion: reduce) {
    .par, .drop-reveal { stroke-dashoffset: 0; transition: none; }
    .par-lbl, .par-west, .city, .tromso, .est { opacity: 1; transition: none; }
  }
</style>

<script>
  (function () {
    var fig = document.querySelector('[data-anim="sixty-floor"]');
    if (!fig) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      fig.classList.add("in"); // CSS above already renders the final state
      return;
    }
    if (!("IntersectionObserver" in window)) {
      fig.classList.add("in");
      return;
    }
    var io = new IntersectionObserver(
      function (entries) {
        for (var i = 0; i < entries.length; i++) {
          if (entries[i].isIntersecting) {
            fig.classList.add("in");
            io.disconnect();
          }
        }
      },
      { threshold: 0.35 }
    );
    io.observe(fig);
  })();
</script>
